{
  "name": "sos-narva-backend",
  "version": "1.0.0",
  "description": "Minimal Node server to connect app to MySQL (XAMPP)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:one": "npm run frontend:build && node server.js",
    "seed": "node run-seed.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build"
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mysql2": "^3.3.0",
    "nodemailer": "^8.0.1"
  }
}